{
  "name": "@jayjiang/byoao",
  "version": "0.5.0",
  "description": "Build Your Own AI OS — Obsidian + AI Agent",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "byoao": "dist/cli/cli-program.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --import tsx src/cli/cli-program.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "src/assets/",
    "src/skills/"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "obsidian",
    "knowledge-os",
    "preset",
    "knowledge-management"
  ],
  "license": "MIT",
  "author": "Jay Jiang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JayJiangCT/BYOAO.git",
    "directory": "byoao"
  },
  "homepage": "https://github.com/JayJiangCT/BYOAO#readme",
  "bugs": {
    "url": "https://github.com/JayJiangCT/BYOAO/issues"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.24",
    "chalk": "^5.0.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.0.0",
    "gray-matter": "^4.0.0",
    "handlebars": "^4.7.0",
    "inquirer": "^9.0.0",
    "semver": "^7.7.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.0",
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/semver": "^7.7.1",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  }
}
